<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E1F5FE">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/txtTituloHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estado actual de la calidad del aire"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#01579B"
                android:layout_marginBottom="6dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:elevation="4dp"
                app:cardCornerRadius="18dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dispositivo"
                            android:textStyle="bold"
                            android:textColor="#333333"
                            android:layout_marginEnd="8dp" />

                        <Spinner
                            android:id="@+id/spDispositivosHome"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1" />
                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/viewCircleEstado"
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:layout_gravity="center_horizontal"
                        android:background="@drawable/bg_circle_good">

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/txtEstado"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Buena"
                                android:textColor="#2E7D32"
                                android:textStyle="bold"
                                android:textSize="22sp" />

                            <TextView
                                android:id="@+id/txtEstadoLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Calidad del aire"
                                android:textColor="#2E7D32"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </FrameLayout>

                    <TextView
                        android:id="@+id/txtUltimaLectura"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Última lectura: --"
                        android:textSize="12sp"
                        android:textColor="#777777"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="4dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="3dp"
                    android:elevation="3dp"
                    app:cardCornerRadius="16dp">
                    <LinearLayout android:orientation="vertical" android:padding="8dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CO₂" android:textStyle="bold" android:textColor="#B71C1C" />
                        <TextView android:id="@+id/txtCO2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-- ppm" android:textSize="18sp" android:textColor="#B71C1C" />
                        <TextView android:id="@+id/txtCO2Objetivo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Objetivo:" android:textSize="11sp" android:textColor="#666666" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="3dp"
                    android:elevation="3dp"
                    app:cardCornerRadius="16dp">
                    <LinearLayout android:orientation="vertical" android:padding="8dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Índice de calidad" android:textStyle="bold" android:textColor="#004D40" />
                        <TextView android:id="@+id/txtIndiceCalidad" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-- / 100" android:textSize="18sp" />
                        <TextView android:id="@+id/txtIndiceNivel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nivel: --" android:textSize="11sp" android:textColor="#666666" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="4dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="3dp"
                    android:elevation="3dp"
                    app:cardCornerRadius="16dp">
                    <LinearLayout android:orientation="vertical" android:padding="8dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Temperatura" android:textStyle="bold" android:textColor="#1565C0" />
                        <TextView android:id="@+id/txtTemp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-- °C" android:textSize="18sp" />
                        <TextView android:id="@+id/txtTempConfort" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Confort: --" android:textSize="11sp" android:textColor="#666666" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="3dp"
                    android:elevation="3dp"
                    app:cardCornerRadius="16dp">
                    <LinearLayout android:orientation="vertical" android:padding="8dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Humedad relativa" android:textStyle="bold" android:textColor="#2E7D32" />
                        <TextView android:id="@+id/txtHum" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-- %" android:textSize="18sp" />
                        <TextView android:id="@+id/txtHumConfort" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Confort: --" android:textSize="11sp" android:textColor="#666666" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardRiesgoSee"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:elevation="3dp"
                app:cardCornerRadius="16dp">
                <LinearLayout android:orientation="vertical" android:padding="8dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Riesgo SEE (Síndrome del Edificio Enfermo)" android:textStyle="bold" android:textColor="#333333" />
                    <TextView android:id="@+id/txtRiesgoSee" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textSize="13sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:elevation="3dp"
                app:cardCornerRadius="16dp">
                <LinearLayout android:orientation="vertical" android:padding="8dp" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Recomendación rápida" android:textStyle="bold" android:textColor="#333333" />
                    <TextView android:id="@+id/txtRecomendacion" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Conectando..." android:textSize="13sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnAyudaHome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Ayuda"
        android:src="@android:drawable/ic_menu_help"
        app:backgroundTint="#A5D6A7"
        app:tint="@android:color/black"
        app:fabCustomSize="36dp"
        app:maxImageSize="20dp"
        app:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.4" />

</androidx.constraintlayout.widget.ConstraintLayout>